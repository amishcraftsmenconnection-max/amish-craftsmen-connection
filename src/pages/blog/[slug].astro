---
import MainLayout from "../../layouts/MainLayout.astro";
import { blogs } from "../../data/blogs.js";

// 1. Tell Astro which static pages to build based on your blog data slugs
export async function getStaticPaths() {
  return blogs.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

// 2. Grab the post data properties safely
const { post } = Astro.props;
---

<MainLayout title={post.title}>
  <article class="article-container">
    <!-- Breadcrumb back navigation line -->
    <a href="/blog" class="back-to-blog">
      <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Back to Chronicles
    </a>

    <!-- Premium Article Meta Banner Header -->
    <header class="article-header">
      <div class="article-meta">
        <span class="category-tag">{post.category}</span>
        <span class="divider">•</span>
        <span class="reading-time">{post.readingTime}</span>
      </div>
      <h1 class="article-title">{post.title}</h1>
      
      <div class="author-card-row">
        <div class="author-avatar">
          {post.author.charAt(0)}
        </div>
        <div class="author-details">
          <p class="author-name">Written by {post.author}</p>
          <p class="publish-date">Published on {post.date}</p>
        </div>
      </div>
    </header>

    <div class="article-accent-line"></div>

    <!-- Main Dynamic Article Body Paragraph Text Area -->
    <div class="article-body">
      <p class="lead-summary">
        {post.summary}
      </p>
      
      <!-- Placeholder content fields -->
      <p>
        Traditional Amish craft techniques have been passed down through generations, prioritizing longevity and structural integrity over speed. By using premium materials and tight joinery frameworks, these designs naturally endure the elements with minimal modern maintenance over decades of active service.
      </p>
      
      <blockquote>
        "True quality means building something once, the right way, so it stands proud for the generations that follow."
      </blockquote>
      
      <p>
        When planning your next property asset additions or structural extensions, collaborating with a dedicated traditional craftsman guarantees a standard of care, honesty, and execution that modern mass-production facilities simply cannot replicate.
      </p>
    </div>
  </article>
</MainLayout>

<style>
  /* ─── PREMIUM EDITORIAL ARTICLE CONTAINER ─── */
  .article-container {
    max-width: 900px; 
    margin: 0 auto;
    padding: 10px 1.5rem 80px 1.5rem; 
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  /* Luxury Navigation Links */
  .back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #2a1a12 !important; /* Fixed: Changed to rich dark brown font color */
    text-decoration: none;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-top: 10px; 
    margin-bottom: 1rem; /* Fixed: Reduced bottom margin to shrink layout gap */
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .back-to-blog:hover {
    opacity: 0.8;
    transform: translateX(-4px); 
  }

  /* ─── FIXED COMPACT HERO HEADER BANNER ─── */
  .article-header {
    background-color: #2b1a11 !important; 
    border-radius: 12px !important;
    padding: 35px 40px 25px 40px !important; /* Fixed: Compressed internal vertical spacing to flatten the block */
    margin: 0 auto 1.5rem auto !important; /* Fixed: Locked tight top margin to close empty link gap */
    max-width: 1200px !important;
    width: 100% !important;
    box-shadow: 0 20px 40px rgba(42, 26, 18, 0.04) !important;
    text-align: center !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    position: relative !important;
    top: 0 !important;
    clear: both !important;
    z-index: 5 !important;
    box-sizing: border-box !important;
  }

  .article-meta {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 1rem !important;
    margin-bottom: 12px !important; 
    font-size: 11px !important; 
    width: 100% !important;
  }

  .category-tag {
    color: #eebb88 !important; 
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.25em !important;
  }

  .divider {
    width: 4px !important;
    height: 4px !important;
    background-color: #ebdccb !important; 
    border-radius: 50% !important;
    display: inline-block !important;
  }

  .reading-time {
    color: #c4b5a4 !important; 
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    font-weight: 500 !important;
  }
  
  .article-title {
    font-size: clamp(24px, 3.2vw, 36px) !important; 
    color: #ffffff !important; 
    font-weight: 300 !important; 
    letter-spacing: -0.01em !important;
    line-height: 1.4 !important; 
    margin: 0 auto 20px auto !important; /* Added clean spacing inside block below title text */
    max-width: 1000px !important; 
  }

  /* ─── BRAND SIGNATURE AUTHOR COMPONENT (CLEAN NO BACKGROUND SKIN) ─── */
  .author-card-row {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important; 
    gap: 0.75rem !important; /* Tightened element separation gap */
    background: transparent !important; /* Fixed: Removed the white background box container color */
    border: none !important; /* Fixed: Destroyed structural outline boundaries */
    padding: 0 !important;
    box-shadow: none !important; /* Fixed: Removed the block shadow effects */
    margin: 0 auto !important;
    width: fit-content !important;
  }

  .author-avatar {
    width: 32px !important; /* Fixed: Compact avatar circle framework profile */
    height: 32px !important;
    background-color: #2a1a12 !important; 
    color: #ebdccb !important; /* Refined off-white monogram tint */
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-weight: 600 !important;
    font-size: 0.85rem !important; /* Fixed: Clean small letter size scaling */
    border: 1px solid rgba(255, 255, 255, 0.15) !important; /* Soft border blends into banner */
    flex-shrink: 0 !important;
  }

  .author-details {
    display: flex !important;
    flex-direction: column !important;
    gap: 0px !important; /* Absolute structural text grouping tightness */
    text-align: left !important;
  }

  .author-name {
    margin: 0 !important;
    font-weight: 500 !important; /* Fixed: Reduced bold thickness values */
    color: #ece6e6 !important; /* Fixed: Inverted white text stands out neatly directly on dark brown layer background */
    font-size: 0.85rem !important; /* Fixed: Much smaller typography layout scale */
  }

  .publish-date {
    margin: 0 !important;
    font-size: 0.75rem !important; /* Fixed: Clean micro-date sub-label typography sizing values */
    color: #c4b5a4 !important; /* Fixed: Readable cream color ensures subtle distinction */
  }

  .article-accent-line {
    height: 1px !important;
    background-color: #ebdccb !important;
    margin: 2.5rem 0 !important;
  }

  /* ─── TYPOGRAPHY RICH CONTENT BODY ─── */
  .article-body {
    color: #2a1a12 !important;
    font-size: 1.15rem !important;
    line-height: 1.85 !important; 
  }

  .article-body p {
    margin: 0 0 1.75rem 0 !important;
  }
  
  .article-body .lead-summary {
    font-size: 1.3rem !important;
    line-height: 1.7 !important;
    color: #5c4f46 !important; 
    font-weight: 400 !important;
    margin-bottom: 2.5rem !important;
    background-color: #fbf9f6 !important; 
    padding: 24px !important;
    border-radius: 6px !important;
    border-left: 3px solid #c5a47e !important;
  }
  
  /* Luxury Blockquote Panel Section */
  blockquote {
    border-left: 3px solid #c5a47e !important; 
    background-color: #fbf9f6 !important; 
    margin: 3rem 0 !important;
    padding: 2rem !important;
    font-style: italic !important;
    font-size: 1.3rem !important;
    color: #2a1a12 !important;
    border-radius: 0px !important; 
    line-height: 1.6 !important;
  }
</style>



