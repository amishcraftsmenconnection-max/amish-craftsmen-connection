}

.display-location-text {
  font-size: 0.95rem;
  color: #60554c;
  margin: 0 0 1.5rem 0;
  display: flex;
  align-items: center;
  gap: 0.25rem;
  font-weight: 500;
}

.card-action-footer {
  margin-top: auto;
  padding-top: 1.25rem;
