---
import MainLayout from "../../layouts/MainLayout.astro";
import { contractors } from "../../data/contractors.js";

export async function getStaticPaths() {
  const dynamicServices = contractors.flatMap(c => 
    c.service ? c.service.split(',').map(s => s.trim()) : []
  );

  const emptyServicesList = [
    "Custom Cabinets",
    "Roofers Siding Specialists",
    "Renovations",
    "Renovation"
  ];

  const allServicesCombined = [...dynamicServices, ...emptyServicesList];
  const uniqueServices = [...new Set(allServicesCombined)];

  return uniqueServices.map(service => ({
    params: {
      service: service.toLowerCase().replaceAll("/", "-").replaceAll(" ", "-")
    }
  }));
}

const { service } = Astro.params;

const filtered = contractors.filter(contractor => {
  if (!contractor.service) return false;
  const individualServices = contractor.service.split(',').map(s => 
    s.trim().toLowerCase().replaceAll("/", "-").replaceAll(" ", "-")
  );
  
  return individualServices.some(s => s.includes(service) || service.includes(s));
});

const formattedTitle = service
  ? service.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')
  : "Our Services";

const activeStates = [...new Set(filtered.map(c => c.state))].filter(Boolean).sort();
---

<MainLayout title={formattedTitle}>
  <div class="services-container">
    <header class="page-header">
      <a href="/services" class="back-link">
        <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to All Services
      </a>
      <p class="subtitle">Amish Craftsmen Connection</p>
      <h1 class="title">{formattedTitle} Specialists</h1>
      <div class="accent-line"></div>
      <p class="description">
        Browse our hand-selected, verified premium Amish craftsmen specializing in high-quality {formattedTitle.toLowerCase()} work.
      </p>

      <!-- 🌟 PREMIUM FILTER DASHBOARD BAR -->
      {filtered.length > 0 && (
        <div class="filter-wrapper">
          <div class="filter-box">
            <div class="select-container">
              <svg class="select-icon" xmlns="http://w3.org" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <select id="stateFilter" class="filter-select">
                <option value="all">All Locations ({filtered.length})</option>
                {activeStates.map(state => {
                  const count = filtered.filter(c => c.state === state).length;
                  return <option value={state.toLowerCase().trim()}>{state} ({count})</option>
                })}
              </select>
            </div>
          </div>
        </div>
      )}
    </header>

    {filtered.length > 0 ? (
      <div>
        <div class="contractors-grid" id="contractorsGrid">
          {filtered.map(contractor => (
            <a href={`/contractors/${contractor.slug}`} class="contractor-premium-link" data-state={contractor.state ? contractor.state.toLowerCase().trim() : ''}>
              <article class="contractor-card">
                
                <!-- 🌟 TOP HALF: SPLIT BUSINESS CARD GRAPHIC HEADER -->
                <div class="card-graphic-header">
                  <div class="graphic-left-content">
                    <h3 class="graphic-firm-name">{contractor.name}</h3>
                    <p class="graphic-sub-badge">Amish Contractor</p>
                    
                    <ul class="graphic-mini-details">
                      <li>📞 {contractor.phone || "No Phone Registered"}</li>
                      <li>🌐 ://amishcraftsmenconnection.com</li>
                      <li>📍 {contractor.city || "Operating Area"}, {contractor.state || "US"}</li>
                      <li>🛠 {contractor.service || "Amish Handiwork"}</li>
                    </ul>
                  </div>
                  
                  <div class="graphic-brand-side">
                    <div class="brand-logo-panel">
                      <div class="logo-mark-svg">
                        <svg width="65" height="45" viewBox="0 0 100 70" fill="none" xmlns="http://w3.org">
                          <path d="M50 5 L95 45 M50 5 L5 45" stroke="#fdf6f0" stroke-width="4" stroke-linecap="round"/>
                          <path d="M35 50 L35 30 L45 30 L45 50 Z" fill="#fdf6f0"/>
                          <path d="M60 45 L75 25 M65 25 L80 45" stroke="#fdf6f0" stroke-width="4" stroke-linecap="round"/>
                        </svg>
                      </div>
                      <span class="logo-brand-text">Amish Craftsmen Connection</span>
                    </div>
                  </div>
                </div>

                <!-- 🌟 BOTTOM HALF: DETAILS CONTENT LAYER -->
                <div class="card-body-content">
                  <div class="badge-row">
                    {contractor.service && contractor.service.split(',').map(s => (
                      <span class="service-pill">{s.trim().toUpperCase()}</span>
                    ))}
                  </div>
                  
                  <h2 class="display-contractor-name">{contractor.name}</h2>
                  
                  <p class="display-location-text">
                    📍 {contractor.city ? `${contractor.city}, ` : ''}{contractor.state || "Operating Area"}
                  </p>
                  
                  <div class="card-action-footer">
                    <span class="action-link-text">View Profile →</span>
                  </div>
                </div>

              </article>
            </a>
          ))}
        </div>

        <!-- Dynamic JS Filter Empty State Target Block -->
        <div id="filterEmptyState" class="empty-state hidden-element">
          <p>No verified craftsmen found in this specific area at the moment.</p>
        </div>
      </div>
    ) : (
      /* 🛠️ FALLBACK UI FOR CHANNELS WITHOUT ACTIVE CONTRACTORS */
      <div class="no-craftsmen-card">
        <div class="icon-alert">⚠️</div>
        <h2>No Craftsmen Found</h2>
        <p class="intro-text">
          We currently do not have verified Amish craftsmen listed online for <strong>{formattedTitle}</strong>.
        </p>
        
        <div class="card-divider"></div>
        
        <p class="action-text">However, our team can still source providers offline! Please contact us directly for an immediate inquiry:</p>
        
        <div class="contact-methods">
          <a href="tel:+18002660037" class="contact-btn phone-btn">
            📞 Call Hotline: +1 800-266-0037
          </a>
          <a href={`mailto:inquire@://amishcraftsmenconnection.com about ${formattedTitle}`} class="contact-btn email-btn">
            ✉️ Email to Inquire
          </a>
        </div>
      </div>
    )}
  </div>
</MainLayout>

<!-- 🌟 FIXED: SINGLE UNIFIED CLIENT FILTER SCRIPT -->
<script>
  function setupStateFilter() {
    const selectEl = document.getElementById('stateFilter') as HTMLSelectElement;
    const gridEl = document.getElementById('contractorsGrid');
    const emptyEl = document.getElementById('filterEmptyState');
    
    if (!selectEl || !gridEl) return;
    
    const cards = gridEl.querySelectorAll('.contractor-premium-link');

    selectEl.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      const selectedValue = target.value;
      let visibleCount = 0;

      cards.forEach(card => {
        const cardHtml = card as HTMLElement;
        const cardState = cardHtml.getAttribute('data-state') || '';

        if (selectedValue === 'all' || cardState === selectedValue) {
          cardHtml.classList.remove('hidden-element');
          visibleCount++;
        } else {
          cardHtml.classList.add('hidden-element');
        }
      });

      if (emptyEl) {
        if (visibleCount === 0) {
          emptyEl.classList.remove('hidden-element');
        } else {
          emptyEl.classList.add('hidden-element');
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', setupStateFilter);
  document.addEventListener('astro:after-swap', setupStateFilter);
</script>

<style>
