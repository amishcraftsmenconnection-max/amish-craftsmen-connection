  .services-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* 🌟 TOP HEADER PANEL */
