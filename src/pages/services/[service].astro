}

.contractor-premium-link:hover .contractor-card {
  transform: translateY(-5px);
  box-shadow: 0 12px 30px rgba(139, 90, 43, 0.14);
}

/* 🌟 TOP HALF: BUSINESS CARD GRAPHIC HEADER */
.card-graphic-header {
  display: flex;
  background: #fdfaf7;
  height: 155px;
  position: relative;
  border-bottom: 1px solid #ebdcd0;
}

.graphic-left-content {
