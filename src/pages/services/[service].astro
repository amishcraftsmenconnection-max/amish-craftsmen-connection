.graphic-mini-details {
  list-style: none;
  padding: 0;
  margin: 0;
  font-size: 0.65rem;
  color: #60554c;
  line-height: 1.5;
}

.graphic-mini-details li {
  white-space: nowrap;
  overflow: hidden;
