    text-align: center;
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #d4a373;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: #f4f1de;
  }

  .subtitle {
    color: #d4a373;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .title {
    font-size: 2.5rem;
    color: #ffffff;
    font-weight: 700;
    margin: 0 0 1rem 0;
  }

  .accent-line {
    width: 60px;
    height: 3px;
    background-color: #d4a373;
    margin: 0 auto 1.5rem auto;
  }

  .description {
    color: #e0dcd5;
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto 2rem auto;
    line-height: 1.6;
  }

  /* 🌟 LOCATION FILTER ELEMENT STYLING */
  .filter-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .filter-box {
    background: #ffffff;
    border: 1px solid #eaddd3;
    padding: 0.5rem 1rem;
    border-radius: 50px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);
}

.select-container {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: #8b5a2b;
}

.filter-select {
  border: none;
  outline: none;
  background: transparent;
  font-size: 0.95rem;
  font-weight: 600;
  color: #2c2520;
  padding-right: 1.5rem;
  cursor: pointer;
  font-family: inherit;
}

/* 🌟 PREMIUM RESPONSIVE GRID MATRIX */
.contractors-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 2rem;
  margin-top: 2rem;
}

.contractor-premium-link {
  text-decoration: none !important;
  color: inherit;
  display: block;
  cursor: pointer;
}

.contractor-card {
  background: #ffffff;
  border: 1px solid #eaddd3;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  height: 100%;
