---
import MainLayout from "../layouts/MainLayout.astro";
import { contractors } from "../data/contractors.js";
---

<MainLayout title="Contractors Directory">
  <section class="directory-section">
    
    <!-- Premium Header Area -->
    <div class="directory-header">
      <h1>Contractors Directory</h1>
      <p class="subtitle">Find and connect with verified, professional local craftsmen in your area.</p>
    </div>

    <!-- Redesigned Search bar Panel -->
    <div class="search-panel">
      <div class="search-wrapper">
        <div class="input-relative">
          <span class="search-icon">🔍</span>
          <input 
            type="text" 
            id="contractorSearchInput" 
            placeholder="Search contractor names..." 
            aria-label="Search contractor names"
          />
        </div>
        <button type="button" id="searchSubmitBtn" class="btn-search">
          Search
        </button>
      </div>
    </div>

    <!-- Contractors Grid Cards Layout Container -->
    <div class="directory-grid" id="contractorsGrid">
      {
        contractors.map(contractor => (
          <div class="contractor-card" data-name={contractor.name.toLowerCase()}>
            <div class="card-image-stub">
              {contractor.image ? (
                <img src={contractor.image} alt={contractor.name} class="card-thumb" />
              ) : (
                <div class="card-placeholder">🛠️</div>
              )}
            </div>
            
            <div class="card-body">
              <span class="card-badge">{contractor.service}</span>
              <h2 class="card-title">
                <a href={`/contractors/${contractor.slug}`}>
                  {contractor.name}
                </a>
              </h2>
              
              <div class="card-meta">
                <span class="meta-item">
                  <span class="meta-icon">📍</span> {contractor.city ? `${contractor.city}, ` : ''}{contractor.state}
                </span>
              </div>
            </div>

            <div class="card-footer">
              <a href={`/contractors/${contractor.slug}`} class="btn-view-profile">
                View Profile &rarr;
              </a>
            </div>
          </div>
        ))
      }
    </div>

<!-- PREMIUM NO RESULTS BLOCK CONTAINER -->
<div id="noResultsBlock" class="no-results hidden-element">
  <div class="no-results-inner">
    <!-- Icon Wrapper -->
    <div class="no-results-icon-box">
      <svg xmlns="http://w3.org" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </div>
    
    <h3>No Craftsmen Found</h3>
    <p class="no-results-message">
      Having trouble reaching this crew? Our Central Dispatch Team can intervene to manually coordinate your build.
    </p>

    <!-- ACTION BUTTONS GROUP -->
    <div class="no-results-actions">
      <a href="tel:+18002660037" class="btn-premium btn-primary">
        <svg xmlns="http://w3.org" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call Central Dispatch
      </a>
      <a href="/contact" class="btn-premium btn-secondary">
        <svg xmlns="http://w3.org" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Email Project Specs
      </a>
    </div>
  </div>
</div>


  </section>
</MainLayout>

<!-- Client-side Interactive Filtering logic script -->
<script>
 function initContractorSearch() {
  const searchInput = document.getElementById('contractorSearchInput') as HTMLInputElement;
  const searchButton = document.getElementById('searchSubmitBtn');
  const cards = document.querySelectorAll('.contractor-card');
  const noResultsBlock = document.getElementById('noResultsBlock');

  if (!searchInput || !cards) return;

  // 🌟 FIX: Force-hide the block on initial load / view swap
  noResultsBlock?.classList.add('hidden-element');

  function handleFiltering() {
    const query = searchInput.value.trim().toLowerCase();
    let totalVisible = 0;

    cards.forEach(card => {
      const name = card.getAttribute('data-name') || '';
      
      if (name.includes(query)) {
        card.classList.remove('hidden-card');
        totalVisible++;
      } else {
        card.classList.add('hidden-card');
      }
    });

    // Toggle based on visible results
    if (totalVisible === 0) {
      noResultsBlock?.classList.remove('hidden-element');
    } else {
      noResultsBlock?.classList.add('hidden-element');
    }
  }

  searchButton?.addEventListener('click', handleFiltering);

  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      handleFiltering();
    }
  });

  searchInput.addEventListener('input', () => {
    if (searchInput.value === '') {
      handleFiltering();
    }
  });
}

initContractorSearch();
document.addEventListener('astro:after-swap', initContractorSearch);

</script>


<style is:global>
  /* PREMIUM SPACE-CONSCIOUS LAYOUT RESET */
  .directory-section {
    max-width: 1100px; /* Brought max container size inward */
    margin: 0 auto;
    padding: 7rem 1.5rem 4rem 1.5rem !important;
    box-sizing: border-box;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    width: 100%;
  }

  /* This forces the element to be hidden when the page loads */
.hidden-element {
  display: none !important;
}


  /* REPROPORTIONED HEADER AREA */
  .directory-header {
    text-align: center;
    margin-bottom: 2.5rem;
    width: 100%;
  }
  .directory-header h1 {
    font-size: 2.5rem !important; /* Shrunk title size down slightly */
    font-weight: 800 !important;
    color: #1a1512 !important;
    margin: 0 0 0.5rem 0 !important;
    letter-spacing: -0.02em;
    display: block !important;
  }
  .directory-header .subtitle {
    font-size: 1.05rem !important;
    color: #6a5e55 !important;
    max-width: 550px;
    margin: 0 auto !important;
    line-height: 1.5;
  }

  /* COMPACT SEARCH BLOCK */
  .search-panel {
    max-width: 500px;
    margin: 0 auto 3rem auto !important;
    width: 100% !important;
    box-sizing: border-box;
    display: block !important;
  }
  .search-wrapper {
    display: flex !important;
    gap: 10px !important;
    background: #ffffff !important;
    padding: 0.4rem !important;
    border-radius: 50px !important;
    border: 1px solid #ebdcd0 !important;
    box-shadow: 0 4px 15px rgba(44, 37, 32, 0.02) !important;
    box-sizing: border-box;
    width: 100% !important;
  }
  .input-relative {
    position: relative !important;
    flex: 1 !important;
    display: flex !important;
    align-items: center !important;
  }
  .search-icon {
    position: absolute !important;
    left: 14px !important;
    font-size: 14px !important;
  }
  .search-wrapper input {
    width: 100% !important;
    padding: 8px 10px 8px 38px !important;
    border: none !important;
    font-size: 14px !important;
    color: #2c2520 !important;
    outline: none !important;
    background: transparent !important;
  }
  .btn-search {
    background: #8b5a2b !important;
    color: #ffffff !important;
    border: none !important;
    padding: 0 20px !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    border-radius: 50px !important;
    cursor: pointer !important;
    height: 38px !important;
  }
  .btn-search:hover {
    background: #5c3a1a !important;
  }

  /* 4-COLUMN COMPACT MATRIX GRID FRAMEWORK */
  .directory-grid {
    display: grid !important;
    /* Increased density by scaling minimum widths down to 260px */
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)) !important;
    gap: 1.75rem !important; /* Shrunk spacing grid down */
    width: 100% !important;
    box-sizing: border-box;
  }

  /* SLEEK VERTICAL PROPORTIONED CARDS */
  .contractor-card {
    background: #ffffff !important;
    border-radius: 10px !important;
    border: 1px solid #ebdcd0 !important;
    box-shadow: 0 4px 15px -2px rgba(44, 37, 32, 0.02) !important;
    overflow: hidden !important;
    display: flex !important;
    flex-direction: column !important;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), 
                box-shadow 0.25s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.25s ease !important;
    box-sizing: border-box;
    width: 100% !important;
  }
  .contractor-card:hover {
    transform: translateY(-4px) !important;
    border-color: #8b5a2b !important;
    box-shadow: 0 15px 25px -6px rgba(139, 90, 43, 0.1) !important;
  }

  /* SHRUNK BUSINESS CARD PREVIEW STUB */
  .card-image-stub {
    width: 100% !important;
    height: 140px !important; /* 🌟 Brought thumbnail frame down from 200px to 140px */
    background: linear-gradient(135deg, #fdfbfa 0%, #f4eee8 100%) !important;
    border-bottom: 1px solid #ebdcd0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    overflow: hidden;
  }
  .card-thumb {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }

  /* INTERNAL TEXT ELEMENT DETAILS */
  .card-body {
    padding: 1.25rem !important; /* Made internal spacing tighter and neat */
    flex: 1 !important;
    display: flex !important;
    flex-direction: column !important;
  }
  .card-badge {
    align-self: flex-start;
    background-color: #f7f4f0 !important;
    color: #8b5a2b !important;
    border: 1px solid #ebdcd0 !important;
    font-size: 0.68rem !important;
    font-weight: 700 !important;
    padding: 0.2rem 0.5rem !important;
    border-radius: 4px !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem !important;
    display: inline-block;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-title {
    font-size: 1.2rem !important; /* Downscaled name header text sizes */
    margin: 0 0 0.5rem 0 !important;
    font-weight: 700 !important;
    line-height: 1.3 !important;
  }
  .card-title a {
    text-decoration: none !important;
    color: #1a1512 !important;
    transition: color 0.15s ease !important;
  }
  .contractor-card:hover .card-title a {
    color: #8b5a2b !important;
  }
  .card-meta {
    font-size: 0.88rem !important;
    color: #5c5046 !important;
    margin-top: auto; /* Pushes location info nicely above footer line */
    padding-bottom: 0.75rem;
  }
  .meta-item {
    display: flex !important;
    align-items: center !important;
    gap: 0.3rem !important;
  }

  /* COMPACT CLEAN CARD FOOTERS */
  .card-footer {
    border-top: 1px solid #f5ede6 !important;
    padding: 0.85rem 1.25rem 1rem 1.25rem !important;
    background: transparent !important;
  }
  .btn-view-profile {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    text-decoration: none !important;
    color: #8b5a2b !important;
    font-weight: 700 !important;
    font-size: 0.88rem !important;
    transition: color 0.15s ease !important;
    width: 100%;
  }
  .btn-view-profile:hover {
    color: #5c3a1a !important;
  }

  /* FALLBACK EMPTY STATES */
  .no-results {
    text-align: center !important;
    padding: 3rem 1.5rem !important;
    background: #fdfbfa !important;
    border: 1px dashed #ebdcd0 !important;
    border-radius: 10px !important;
    color: #6a5e55 !important;
    max-width: 400px;
    margin: 2rem auto 0 auto !important;
  }
  .hidden-card {
    display: none !important;
  }
  /* Card Container */
.no-results {
  background: #ffffff;
  border: 1px solid #eaeaea;
  border-radius: 16px;
  padding: 40px 24px;
  max-width: 560px;
  margin: 32px auto;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
}

/* Base Utility to handle visibility */
.hidden-element {
  display: none !important;
}

/* Elegant Icon Wrapper */
.no-results-icon-box {
  background: #f7f7f9;
  color: #71717a;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
}

/* Typography styling */
.no-results h3 {
  font-size: 20px;
  font-weight: 600;
  color: #18181b;
  margin: 0 0 10px 0;
  letter-spacing: -0.01em;
}

.no-results-message {
  font-size: 14px;
  line-height: 1.6;
  color: #71717a;
  max-width: 440px;
  margin: 0 auto 28px;
}

/* Layout for buttons */
.no-results-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

/* Base button specifications */
.btn-premium {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 22px;
  font-size: 14px;
  font-weight: 550;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.2s ease-in-out;
}

/* Primary Call Action Button */
.btn-primary {
  background: #18181b;
  color: #ffffff;
  border: 1px solid #18181b;
}

.btn-primary:hover {
  background: #27272a;
  border-color: #27272a;
  transform: translateY(-1px);
}

/* Secondary Action Button */
.btn-secondary {
  background: #ffffff;
  color: #27272a;
  border: 1px solid #e4e4e7;
}

.btn-secondary:hover {
  background: #f4f4f5;
  border-color: #d4d4d8;
  transform: translateY(-1px);
}

</style>
