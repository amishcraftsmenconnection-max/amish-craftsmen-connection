---
import MainLayout from "../layouts/MainLayout.astro";
// Change line 3 from whatever it is to this exact path string:
import { blogs } from "../data/blogs.js";
---

<MainLayout title="Our Blog">
  <div class="blog-container">
    <!-- Premium Header -->
    <header class="blog-header">
      <p class="subtitle">Amish Craftsmen Connection</p>
      <h1 class="title">Craftsmanship Chronicles</h1>
      <div class="accent-line"></div>
      <p class="description">
        Expert advice, traditional construction techniques, and maintenance guides straight from certified master traditional craftsmen.
      </p>
    </header>

    <!-- Blog Responsive Matrix Grid -->
    <div class="blog-grid">
      {blogs.map(post => (
        <article class="blog-card">
          <!-- Optional Placeholder Image Container -->
          <div class="blog-image-wrapper">
            <div class="placeholder-img-graphic">
              <svg xmlns="http://w3.org" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M4 22V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v18Z"/><path d="M12 18h.01"/><path d="M8 6h8"/><path d="M8 10h8"/><path d="M8 14h4"/></svg>
            </div>
          </div>

          <div class="blog-content">
            <div class="blog-meta-row">
              <span class="blog-category">{post.category}</span>
              <span class="blog-time">{post.readingTime}</span>
            </div>

            <h2 class="blog-title-text">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h2>

            <p class="blog-summary-text">{post.summary}</p>

            <div class="blog-footer">
              <div class="blog-author-info">
                <span class="author-name">By {post.author}</span>
                <span class="post-date">{post.date}</span>
              </div>
              <a href={`/blog/${post.slug}`} class="read-more-btn">
                Read Article
                <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</MainLayout>

<style>
  /* 🌟 PREMIUM LAYOUT FRAMEWORK */
  .blog-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem 1.5rem; /* Balanced cushion space below navigation */
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }
  
    /* 🌟 FIXED MINIMALIST LUXURY HEADER PANEL (EXACT SIZE MATCH) */
  .blog-header {
    text-align: center !important;
    max-width: 1200px !important; /* Locks width constraint to match contact and services banners */
    width: 100% !important;
    margin: 0 auto 40px auto !important; /* Fixed: Removed negative margin to clear space below navbar */
    padding: 30px 40px !important; /* Fixed: Keeps the container height flat and perfectly even */
    background-color: #2b1a11 !important; 
    border-radius: 12px !important;
    box-sizing: border-box !important;
    box-shadow: 0 20px 40px rgba(43, 26, 17, 0.05) !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    position: relative !important;
    top: 0 !important;
    clear: both !important;
    z-index: 5 !important;
  }

  .subtitle {
    color: #eebb88 !important; /* Crisp luxury gold variable accent for readability */
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin-bottom: 0.75rem;
    display: block;
  }
  .title {
    font-size: 3rem;
    color: #ffffff !important; /* Forced to absolute brilliant white text */
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem 0;
  }
  .accent-line {
    width: 45px;
    height: 2px;
    background-color: #eebb88 !important; /* Matches premium gold variable line asset */
    margin: 0 auto 1.75rem auto;
  }
  .description {
    color: #c4b5a4 !important; /* Soft timber cream for clear readability */
    font-size: 1.15rem;
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.65;
    font-weight: 400;
  }


  /* 🌟 MASTER BLOG CARD GRID */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 3rem; /* Extra space to let the luxury cards breathe */
  }

  /* 🌟 PREMIUM HOVER CARDS */
  .blog-card {
    background: #ffffff;
    border: 1px solid #ebdcd0;
    border-radius: 12px; /* Smoother corner radius */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 20px -2px rgba(44, 37, 32, 0.03); /* Soft ambient shadows */
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), 
                box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-6px);
    border-color: #8b5a2b;
    box-shadow: 0 20px 35px -8px rgba(139, 90, 43, 0.12); /* Warm, branded hover glow */
  }
  
  /* 🌟 HIGH-END ACCENTED IMAGE WRAPPER */
  .blog-image-wrapper {
    height: 220px;
    background: linear-gradient(135deg, #fdfbfa 0%, #f4eee8 100%); /* Sophisticated subtle gradient */
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #ebdcd0;
    position: relative;
  }
  /* Decorative elegant inner frame stripe */
  .blog-image-wrapper::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: #8b5a2b;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .blog-card:hover .blog-image-wrapper::after {
    opacity: 1; /* Glow accent line shows up instantly on hover */
  }
  .placeholder-img-graphic {
    color: #d8c4b4;
    transition: transform 0.3s ease, color 0.3s ease;
  }
  .blog-card:hover .placeholder-img-graphic {
    transform: scale(1.1);
    color: #8b5a2b;
  }

  /* 🌟 INNER CARD CONTENT AREA */
  .blog-content {
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .blog-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .blog-category {
    background-color: #f7f4f0;
    color: #8b5a2b;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid #ebdcd0;
  }
  .blog-time {
    font-size: 0.8rem;
    color: #8e8074;
    font-weight: 500;
  }

  /* 🌟 TYPOGRAPHY SETTINGS */
  .blog-title-text {
    font-size: 1.45rem;
    color: #2c2520;
    margin: 0 0 1rem 0;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }
  .blog-title-text a {
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
  }
  .blog-title-text a:hover {
    color: #8b5a2b;
  }
  .blog-summary-text {
    color: #5c5046;
    font-size: 0.98rem;
    line-height: 1.65;
    margin: 0 0 2.5rem 0; /* Keeps descriptions separated from button panel */
  }
  
  /* 🌟 UNIFIED BOTTOM ROW ALIGNMENT */
  .blog-footer {
    margin-top: auto; /* Aligns all card buttons perfectly to the same line */
    border-top: 1px solid #f5ede6;
    padding-top: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .blog-author-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .author-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: #2c2520;
  }
  .post-date {
    font-size: 0.8rem;
    color: #8e8074;
  }

  /* 🌟 INTERACTIVE ACTION CALL TO ACTIONS */
  .read-more-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    color: #8b5a2b;
    font-weight: 700;
    font-size: 0.9rem;
    transition: color 0.15s ease;
  }
  .read-more-btn svg {
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .read-more-btn:hover {
    color: #5c3a1a;
  }
  .read-more-btn:hover svg {
    transform: translateX(5px); /* Smooth premium arrow bounce interaction */
  }
</style>
