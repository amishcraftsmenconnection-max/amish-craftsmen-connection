---
import MainLayout from "../layouts/MainLayout.astro";
import { contractors } from "../data/contractors.js";
---

<MainLayout title="Search Results">
  <div class="search-page-wrapper">
    
    <div class="search-header-group">
      <a href="/" class="back-link">← Back to Search</a>
      <p class="search-summary">
        Showing <strong id="serviceDisplay">...</strong> contractors located in: <strong id="stateDisplay">...</strong>
      </p>
    </div>

    <!-- Container holds all cards, client script handles the extraction and filtering directly -->
    <div class="grid" id="contractorGrid">
      {contractors.map((contractor) => (
        <div 
          class="split-card contractor-profile-card" 
          data-state={contractor.state.toLowerCase().trim()}
          data-services={contractor.service.toLowerCase().trim()}
        >
          <!-- LEFT SIDE: THE GRAPHIC CARD CONTAINER -->
          <div class="card-graphic-pane">
            {contractor.image ? (
              <img src={contractor.image} alt={contractor.name} class="split-card-img" />
            ) : (
              <div class="no-image-placeholder">No Image Available</div>
            )}
          </div>

          <!-- RIGHT SIDE: CONTRACTOR DETAILS -->
          <div class="card-info-pane">
            <h3>{contractor.name}</h3>
            <p class="service-tag">{contractor.service}</p>
            <p class="location-tag">📍 {contractor.city}, {contractor.state}</p>
            <a href={`/contractors/${contractor.slug}`} class="profile-btn">
              View Profile
            </a>
          </div>
        </div>
      ))}
    </div> <!-- CLOSED: contractorGrid -->

    <!-- Fallback message if zero matches occur -->
    <div class="no-results" id="emptyMessage" style="display: none;">
      <div class="no-results-card">
        <div class="search-icon">
          <svg xmlns="http://w3.org" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#8c8c8c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </div>
        
        <h2>No Craftsmen Found</h2>
        
        <p>Having trouble reaching this crew? Our Central Dispatch Team can intervene to manually coordinate your build.</p>
        
        <div class="button-group">
          <a href="tel:+18002660037" class="btn btn-dark">
            <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            Call Central Dispatch
          </a>
          
          <a href="/contact" class="btn btn-light">
            <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            Email Project Specs
          </a>
        </div>
      </div>
    </div>

  </div> <!-- CLOSED: search-page-wrapper -->
</MainLayout>





<!-- CLIENT SIDE LOOKUP ENGINE BACKEND -->
<script>
  // 1. Read parameters directly from the browser window search string layout
  const params = new URLSearchParams(window.location.search);
  const rawState = params.get('state') || "";
  const rawService = params.get('service') || "";

  const targetState = rawState.trim().toLowerCase();
  const targetService = rawService.trim().toLowerCase();

  // 2. Update descriptive text elements on screen
  const stateDisplay = document.getElementById('stateDisplay');
  const serviceDisplay = document.getElementById('serviceDisplay');
  
  if (stateDisplay) stateDisplay.textContent = rawState || "All States";
  if (serviceDisplay) serviceDisplay.textContent = rawService || "All Services";

  // 3. Strict filtering matching loops
  const cards = document.querySelectorAll('.contractor-profile-card');
  let matchCount = 0;

  cards.forEach((card) => {
    const cardState = card.getAttribute('data-state') || "";
    const cardServicesText = card.getAttribute('data-services') || "";

    // Parse out services string by commas and slashes to evaluate items distinctly
    const servicesArray = cardServicesText.split(/[,/]+/).map(s => s.trim());

    // Evaluate matching checks
    const stateMatches = !targetState || cardState === targetState;
    
    // Checks if the chosen service keyword exactly fits any index item inside their metadata line
    const serviceMatches = !targetService || 
                           servicesArray.includes(targetService) || 
                           cardServicesText.includes(targetService);

    if (stateMatches && serviceMatches) {
      (card as HTMLElement).style.setProperty('display', 'flex', 'important');
      matchCount++;
    } else {
      (card as HTMLElement).style.setProperty('display', 'none', 'important');
    }
  });

  // Toggle feedback alert view if zero entries validate successfully
  const emptyMsg = document.getElementById('emptyMessage');
  if (emptyMsg) {
    emptyMsg.style.display = matchCount === 0 ? 'block' : 'none';
  }
</script>

<style>
  /* --- DESKTOP STRUCTURE BASE --- */
  .search-page-wrapper {
    max-width: 1200px !important;
    margin: 110px auto 60px auto !important; 
    padding: 0 20px !important;
    box-sizing: border-box !important;
  }

  .search-header-group {
    display: flex !important;
    flex-direction: column !important;
    gap: 12px !important; 
    margin-bottom: 25px !important; 
    text-align: left !important;
  }

  .back-link {
    color: #5c3b28 !important;
    text-decoration: none !important;
    font-weight: bold !important;
    font-size: 0.95rem !important;
    display: inline-block !important;
  }

  .back-link:hover { text-decoration: underline !important; }

  .search-summary {
    font-size: 1.2rem !important;
    color: #2b1a11 !important;
    margin: 0 !important; 
    padding: 0 !important;
  }

  .search-summary strong {
    color: #5c3b28 !important;
  }

  .grid {
    display: flex !important;
    flex-direction: column !important;
    gap: 25px !important;
    width: 100% !important;
  }

  .split-card {
    background: #ffffff !important;
    border-radius: 12px !important;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.06) !important;
    display: flex !important;
    flex-direction: row !important;
    width: 100% !important;
    overflow: hidden !important;
    box-sizing: border-box !important;
    border: 1px solid #e6e0d4 !important;
  }

  .card-graphic-pane {
    flex: 1 !important;
    max-width: 320px !important;
    background: #fdfbf7 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 15px !important;
  }

  .split-card-img {
    width: 100% !important;
    height: auto !important;
    object-fit: contain !important;
    border-radius: 6px !important;
  }

  .card-info-pane {
    flex: 1.5 !important;
    padding: 30px !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: center !important;
    text-align: left !important;
  }

  .card-info-pane h3 {
    margin: 0 0 8px 0 !important;
    font-size: 1.5rem !important;
    color: #2b1a11 !important;
    font-weight: 700 !important;
  }

  .service-tag {
    color: #5c3b28 !important;
    font-weight: 600 !important;
    font-size: 1rem !important;
    margin: 0 0 8px 0 !important;
  }

  .location-tag {
    color: #666 !important;
    font-size: 0.9rem !important;
    margin: 0 0 20px 0 !important;
  }

  .profile-btn {
    display: inline-block !important;
    align-self: flex-start !important;
    padding: 10px 22px !important;
    background: #5c3b28 !important;
    color: white !important;
    border-radius: 6px !important;
    font-weight: bold !important;
    text-decoration: none !important;
  }

  .no-results {
    text-align: center !important;
    padding: 60px 40px !important;
    background: #fdfbf7 !important;
    border-radius: 12px !important;
    border: 2px dashed #dcd8d0 !important;
  }

  @media (max-width: 768px) {
    .search-page-wrapper {
      margin-top: 130px !important;
      padding: 0 15px !important;
    }
    .split-card { flex-direction: column !important; }
    .card-graphic-pane { max-width: 100% !important; width: 100% !important; }
    .card-info-pane { padding: 20px !important; text-align: center !important; align-items: center !important; }
    .profile-btn { width: 100% !important; box-sizing: border-box !important; }
  }

  <style>
/* Base Layout Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  font-family: sans-serif;
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  border-radius: 6px;
  box-sizing: border-box;
}

.btn-dark {
  background-color: #161616;
  color: #ffffff;
}

.btn-light {
  background-color: #ffffff;
  color: #161616;
  border: 1px solid #e2e2e2;
}

/* --- PREMIUM NO-RESULTS CARD LAYOUT --- */

.no-results-card {
  background-color: #ffffff;
  border-radius: 16px; /* Smooth elegant curves */
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04), 0 2px 8px rgba(0, 0, 0, 0.02); /* Soft luxury shadow */
  max-width: 580px;
  margin: 60px auto; 
  padding: 50px 40px;
  text-align: center;
  box-sizing: border-box;
  border: 1px solid rgba(0, 0, 0, 0.03); /* Subtle premium border accent */
}

/* Elegant Icon Container */
.search-icon {
  margin-bottom: 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 64px;
  background-color: #fbf8f3; /* Matching your cream color tone */
  border-radius: 50%;
  color: #8c8c8c;
}

/* Typography Enhancements */
.no-results-card h2 {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 24px;
  color: #1a1a1a;
  margin: 0 0 14px 0;
  font-weight: 600;
  letter-spacing: -0.3px;
}

.no-results-card p {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 15px;
  color: #666666;
  line-height: 1.6;
  margin: 0 0 36px 0;
  padding: 0 10px;
}

/* Button Configuration Layout */
.button-group {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}

/* High-End Button Base Styles */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 14px 28px;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  border-radius: 8px;
  box-sizing: border-box;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); /* Premium fluid hover shift */
  cursor: pointer;
}

/* Premium Dark Button (Call Central Dispatch) */
.btn-dark {
  background-color: #1a1a1a; /* Clean modern dark slate */
  color: #ffffff;
  border: 1px solid #1a1a1a;
}

.btn-dark:hover {
  background-color: #333333;
  border-color: #333333;
  transform: translateY(-2px); /* Subtle elevate animation */
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
}

/* Premium Light Button (Email Project Specs) */
.btn-light {
  background-color: #ffffff;
  color: #1a1a1a;
  border: 1px solid #e2e2e2;
}

.btn-light:hover {
  background-color: #fbf8f3; /* Blends nicely with background on hover */
  border-color: #cccccc;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.05);
}

/* Keep internal SVG icons crisp and clean */
.btn svg {
  flex-shrink: 0;
  transition: transform 0.2s ease;
}

.btn:hover svg {
  transform: scale(1.05);
}

</style>
