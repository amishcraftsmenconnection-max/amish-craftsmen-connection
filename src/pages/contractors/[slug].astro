    font-size: 0.95rem;
    background-color: #ffffff;
    border: 1px solid #ebdcd0;
    border-radius: 6px;
    color: #1a1512;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .input-group input:focus,
  .select-wrapper select:focus,
  .modal-input-group textarea:focus {
    border-color: #8b5a2b;
    box-shadow: 0 0 0 3px rgba(139, 90, 43, 0.05);
  }
  .select-wrapper {
    position: relative;
    width: 100%;
  }
  .select-wrapper select {
    appearance: none;
    padding-right: 2rem;
    cursor: pointer;
    font-family: inherit;
  }
  .select-wrapper::after {
    content: "▼";
    font-size: 0.65rem;
    color: #8b5a2b;
    position: absolute;
    right: 1.15rem;
    top: 50%;
