    color: #1a1512;
    font-weight: 700;
  }

  /* 🌟 PREMIUM REVIEWS DESIGN MATRIX */
  .reviews-section-panel {
    border-top: 1px solid #f5ede6;
    margin-top: 4rem;
    padding-top: 3rem;
  }
  .reviews-header-row {
    display: flex;
