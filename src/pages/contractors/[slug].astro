---
import MainLayout from "../../layouts/MainLayout.astro";
import { contractors } from "../../data/contractors.js";

export async function getStaticPaths() {
  return contractors.map(contractor => ({
    params: { slug: contractor.slug },
    props: { contractor }
  }));
}

const { contractor } = Astro.props;
---

<MainLayout title={`${contractor.name} | Verified Craftsman`}>
  <div class="premium-profile-container">
    
    <!-- Elegant Navigation -->
    <nav class="profile-nav">
      <a href="/contractors" class="minimal-back-btn">
        <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Directory
      </a>
      <span class="nav-sep">/</span>
      <span class="nav-current">{contractor.name}</span>
    </nav>

    <!-- Unified Editorial Grid -->
    <div class="editorial-grid">
      
      <!-- LEFT COLUMN: The Story & Profile -->
      <main class="editorial-main">
        <span class="editorial-eyebrow">Verified Amish Craftsman</span>
        <h1 class="editorial-title">{contractor.name}</h1>
        
        <div class="editorial-location">
          <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          {contractor.city ? `${contractor.city}, ` : ''}{contractor.state}
        </div>

        <!-- Clean Separated Service Chips -->
        <div class="editorial-chips">
          {contractor.service && contractor.service.split(',').map(s => (
            <span class="service-chip">{s.trim()}</span>
          ))}
        </div>

        <div class="editorial-divider"></div>

        <p class="editorial-bio">
          {contractor.description}
        </p>

        <!-- Premium Quick Contact Strip -->
        <div class="editorial-contact-strip">
  <div class="contact-box">
    <span class="contact-label">Direct Phone Line</span>
    <a href={`tel:${contractor.phone.replace(/[^0-9]/g, '')}`} class="btn-call-contractor">
      <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span>Call Contractor</span>
    </a>
  </div>
          <div class="contact-box">
            <span class="contact-label">Coverage Area</span>
            <span class="contact-value-text">{contractor.state} Statewide</span>
          </div>
        </div>

        <!-- PREMIUM REVIEWS FEED SECTION -->
        <section class="reviews-section-panel">
          <div class="reviews-header-row">
            <div>
              <h2 class="section-title">Customer Reviews</h2>
              <div class="rating-summary-row">
                <span class="star-rating-display">★★★★★</span>
                <span class="rating-text-count">5.0 out of 5 (2 Reviews)</span>
              </div>
            </div>
            <button type="button" id="openReviewModalBtn" class="btn-write-review">
              Leave a Review
            </button>
          </div>

          <div class="reviews-feed-list">
            <div class="review-card-item">
              <div class="review-meta-line">
                <strong>Samuel K.</strong>
                <span class="review-date-badge">Verified Client • June 2026</span>
              </div>
              <div class="review-stars">★★★★★</div>
              <p class="review-comment-text">Outstanding structural execution. The team arrived exactly on time and finished our building layout ahead of schedule. Absolute traditional excellence.</p>
            </div>

            <div class="review-card-item">
              <div class="review-meta-line">
                <strong>Rebecca M.</strong>
                <span class="review-date-badge">Verified Client • May 2026</span>
              </div>
              <div class="review-stars">★★★★★</div>
              <p class="review-comment-text">Very honest communication and meticulous attention to detail. Highly recommend their craftsmanship services to anyone requiring durable installations.</p>
            </div>
          </div>
        </section>
      </main>

            <!-- RIGHT COLUMN: Estimate Form & Enhancify Financing Stacked Panel -->
      <aside class="editorial-sidebar">
        
        <!-- 1. YOUR ORIGINAL ESTIMATE FORM (REMAINS EXACTLY THE SAME) -->
        <div class="minimal-form-box">
          <h2 class="form-heading">Book your Service</h2>
          <p class="form-subheading">Send a direct inquiry regarding project scopes and scheduling availability.</p>
          
          <form class="clean-form">
            <div class="form-row">
              <div class="input-group">
                <label>First Name</label>
                <input type="text" placeholder="John" required />
              </div>
              <div class="input-group">
                <label>Last Name</label>
                <input type="text" placeholder="Doe" required />
              </div>
            </div>

            <div class="form-row">
              <div class="input-group">
                <label>Email Address</label>
                <input type="email" placeholder="john@example.com" required />
              </div>
              <div class="input-group">
                <label>Phone Number</label>
                <input type="tel" placeholder="(555) 000-0000" required />
              </div>
            </div>

            <div class="input-group">
              <label>Service Needed</label>
              <div class="select-wrapper">
                <select required>
                  <option value="" disabled selected>Select a service...</option>
                  {contractor.service && contractor.service.split(',').map(s => (
                    <option value={s.trim().toLowerCase()}>{s.trim()}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="input-group">
              <label>Project Site Address</label>
              <input type="text" placeholder="Street address, city, state" required />
            </div>

            <button type="submit" class="premium-submit-btn">
              Send Book Request
            </button>
          </form>
        </div>

                <!-- 2. NEW ENHANCIFY PREMIUM WIDGET CONTAINER (BULLETPROOF DIRECT EMBED) -->
                <!-- 2. PREMIUM BRANDED FINANCING DASHBOARD MODULE -->
        <div class="minimal-form-box financing-box-margin">
          <h2 class="form-heading">Project Financing</h2>
          <p class="form-subheading">Crews prioritize projects with verified capital. Verify
            up to $100,000 via Enhancify no credit impact to present a 'Funded' Status. 
            Check customized lending availability, loan terms, and estimated monthly payments instantly through Enhancify.</p>
          
          <!-- Premium Branded CTA Area -->
          <div class="custom-financing-action-block">
            <div class="lenders-badge-row">
              <span class="lender-chip">0% Promo APR Available</span>
              <span class="lender-chip">550+ FICO Welcome</span>
            </div>
            
            <!-- Secure Direct Navigation Link Portal Button -->
            <a 
              href="https://www.enhancify.com/amishcraftsmenconnection?utm_source=full_page_widget" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="custom-enhancify-btn"
            >
              <span>Apply for Financing</span>
              <svg xmlns="http://w3.org" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            
            <p class="secure-notice-text">🔒 Safe & Secure. Checking rates will not impact your credit score.</p>
          </div>
        </div>



      </aside>


    </div>
  </div>

  <!-- PREMIUM FLOATING MODAL INTERNALS CONTAINER (HIDDEN VIA FORCE INLINE RULES BY DEFAULT) -->
  <div id="reviewModalWindow" class="modal-overlay-backdrop" style="display: none !important;">
    <div class="modal-card-surface">
      
      <!-- Step 1 View: Contact Validation Form Panel -->
      <div id="modalStep1" class="modal-step-view">
        <div class="modal-header">
          <h3>Verify Your Experience</h3>
          <p>To ensure all ratings on our directory are authentic, please verify your details before posting.</p>
        </div>
        <div class="modal-form-body">
          <div class="modal-input-group">
            <label for="verifyEmail">Email Address</label>
            <input type="email" id="verifyEmail" placeholder="you@example.com" />
          </div>
          <div class="modal-input-group">
            <label for="verifyPhone">Phone Number</label>
            <input type="tel" id="verifyPhone" placeholder="(555) 000-0000" />
          </div>
          <p id="verifyErrorLog" class="modal-error-message" style="display: none;">Please fill out both fields correctly to proceed.</p>
          <div class="modal-actions-row">
            <button type="button" id="closeModalBtn" class="btn-modal-cancel">Cancel</button>
            <button type="button" id="submitVerifyBtn" class="btn-modal-primary">Next Step</button>
          </div>
        </div>
      </div>

      <!-- Step 2 View: Comments Data Fields Input Panel -->
      <div id="modalStep2" class="modal-step-view" style="display: none;">
        <div class="modal-header">
          <h3>Write Your Review</h3>
          <p>Sharing your honest project feedback helps other homeowners select premium contractors.</p>
        </div>
        <div class="modal-form-body">
          <div class="modal-input-group">
            <label for="ratingScoreSelect">Select Rating</label>
            <div class="select-wrapper">
              <select id="ratingScoreSelect">
                <option value="5">★★★★★ (5 Stars)</option>
                <option value="4">★★★★☆ (4 Stars)</option>
                <option value="3">★★★☆☆ (3 Stars)</option>
                <option value="2">★★☆☆☆ (2 Stars)</option>
                <option value="1">★☆☆☆☆ (1 Star)</option>
              </select>
            </div>
          </div>
          <div class="modal-input-group">
            <label for="reviewCommentInput">Your Detailed Comment</label>
            <textarea id="reviewCommentInput" rows="4" placeholder="Describe the quality of work, cleanup, communication, and overall dependability..."></textarea>
          </div>
          <div class="modal-actions-row">
            <button type="button" id="backToStep1Btn" class="btn-modal-cancel">Go Back</button>
            <button type="button" id="publishReviewBtn" class="btn-modal-primary">Publish Review</button>
          </div>
        </div>
      </div>

    </div>
  </div>
</MainLayout>

<!-- BULLETPROOF INTERACTIVE CONTROLS SCRIPT ENGINE -->
<script>
  function initReviewEngine() {
    const openBtn = document.getElementById('openReviewModalBtn');
    const closeBtn = document.getElementById('closeModalBtn');
    const modalWindow = document.getElementById('reviewModalWindow');
    const nextBtn = document.getElementById('submitVerifyBtn');
    const backBtn = document.getElementById('backToStep1Btn');
    const publishBtn = document.getElementById('publishReviewBtn');
    
    const step1Panel = document.getElementById('modalStep1');
    const step2Panel = document.getElementById('modalStep2');
    const errorLog = document.getElementById('verifyErrorLog');
    
    const emailInput = document.getElementById('verifyEmail') as HTMLInputElement;
    const phoneInput = document.getElementById('verifyPhone') as HTMLInputElement;
    const ratingSelect = document.getElementById('ratingScoreSelect') as HTMLSelectElement;
    const commentInput = document.getElementById('reviewCommentInput') as HTMLTextAreaElement;
    const reviewsFeedList = document.querySelector('.reviews-feed-list');

    // Dynamically fetch contractor slug from active path string
    const currentSlug = window.location.pathname.split('/').pop() || 'default';
    const storageKey = `reviews_${currentSlug}`;

    if (!openBtn || !modalWindow || !reviewsFeedList) return;

    // AUTOMATION STEP 1: Load saved reviews on load instantly
    function loadLocalReviews() {
      const saved = localStorage.getItem(storageKey);
      if (!saved) return;

      const items = JSON.parse(saved);
      items.forEach((item: any) => {
        renderReviewElement(item.name, item.stars, item.comment, item.date);
      });
      updateReviewHeaderCounter(items.length);
    }

    function renderReviewElement(name: string, starsCount: number, comment: string, dateStr: string) {
      const starString = '★'.repeat(starsCount) + '☆'.repeat(5 - starsCount);
      const cardHtml = document.createElement('div');
      cardHtml.className = 'review-card-item custom-local-post';
      cardHtml.innerHTML = `
        <div class="review-meta-line">
          <strong>${name}</strong>
          <span class="review-date-badge">Verified Client • ${dateStr}</span>
        </div>
        <div class="review-stars">${starString}</div>
        <p class="review-comment-text">${comment}</p>
      `;
      // Insert new reviews directly to the top of the feed list layout
      reviewsFeedList!.insertBefore(cardHtml, reviewsFeedList!.firstChild);
    }

    function updateReviewHeaderCounter(customCount: number) {
      const counterText = document.querySelector('.rating-text-count');
      const baseTotal = 2 + customCount; // Accounts for your 2 core fallback hardcoded layout reviews
      if (counterText) {
        counterText.textContent = `5.0 out of 5 (${baseTotal} Reviews)`;
      }
    }

    // Modal view window click triggers
    openBtn.addEventListener('click', () => {
      modalWindow.style.setProperty('display', 'flex', 'important');
      step1Panel!.style.display = 'block';
      step2Panel!.style.display = 'none';
      errorLog!.style.display = 'none';
    });

    closeBtn?.addEventListener('click', () => {
      modalWindow.style.setProperty('display', 'none', 'important');
    });

    nextBtn?.addEventListener('click', () => {
      if (!emailInput.value.trim() || !phoneInput.value.trim()) {
        errorLog!.style.display = 'block';
      } else {
        errorLog!.style.display = 'none';
        step1Panel!.style.display = 'none';
        step2Panel!.style.display = 'block';
      }
    });

    backBtn?.addEventListener('click', () => {
      step2Panel!.style.display = 'none';
      step1Panel!.style.display = 'block';
    });

    // AUTOMATION STEP 2: Intercept submit, save to storage, inject into HTML grid
    publishBtn?.addEventListener('click', () => {
      if (!commentInput.value.trim()) {
        alert('Please provide a comment detail message row before publishing.');
        return;
      }

      // Grab user parameters data models safely
      const rawEmail = emailInput.value.trim();
      const extractedName = rawEmail.split('@')[0];
      const parsedName = extractedName.charAt(0).toUpperCase() + extractedName.slice(1);
      
      const ratingStarsValue = parseInt(ratingSelect.value) || 5;
      const commentMessageText = commentInput.value.trim();
      
      const currentLocalDate = new Date();
      const formattedDateLine = currentLocalDate.toLocaleDateString('en-US', {
        month: 'long',
        year: 'numeric'
      });

      // Construct storage payload package strings safely
      const newReviewPayload = {
        name: parsedName,
        stars: ratingStarsValue,
        comment: commentMessageText,
        date: formattedDateLine
      };

      const existingData = localStorage.getItem(storageKey);
      const reviewsArray = existingData ? JSON.parse(existingData) : [];
      reviewsArray.push(newReviewPayload);
      localStorage.setItem(storageKey, JSON.stringify(reviewsArray));

      // Instantly inject layout block to screen viewport frame right away
      renderReviewElement(parsedName, ratingStarsValue, commentMessageText, formattedDateLine);
      updateReviewHeaderCounter(reviewsArray.length);

      // Reset and clear local modal workspace text states fields
      modalWindow.style.setProperty('display', 'none', 'important');
      emailInput.value = '';
      phoneInput.value = '';
      commentInput.value = '';
      ratingSelect.value = '5';
    });

    // Run active load calls
    loadLocalReviews();
  }

  // Bind execution triggers perfectly matching dynamic view router engine frameworks
  document.addEventListener('DOMContentLoaded', initReviewEngine);
  document.addEventListener('astro:after-swap', initReviewEngine);
</script>


<style is:global>
  /* EDITORIAL MAIN CONTAINMENTS */
  .premium-profile-container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 8rem 1.5rem 5rem 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /*  NAVIGATION LINKS */
  .profile-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 3.5rem;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .minimal-back-btn {
    color: #8b5a2b;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 600;
  }
  .minimal-back-btn:hover {
    color: #5c3a1a;
  }
  .nav-sep {
    color: #dcd1c4;
  }
  .nav-current {
    color: #7a6e65;
  }

  /* 🌟 DIRECTORY INTERNALS GRID */
  .editorial-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4.5rem;
    align-items: start;
  }
  @media (max-width: 960px) {
    .editorial-grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
  }

  .editorial-main {
    padding-right: 1rem;
  }
  .editorial-eyebrow {
    color: #8b5a2b;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    display: block;
    margin-bottom: 0.5rem;
  }
  .editorial-title {
    font-size: 2.75rem;
    color: #1a1512;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem 0;
  }
  .editorial-location {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #6a5e55;
    font-size: 1.05rem;
    font-weight: 500;
