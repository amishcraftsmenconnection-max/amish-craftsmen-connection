<!-- LOGICAL CLIENT INTERACTION ENGINE -->
<script is:inline>
  // ─── 1. LEAD CAPTURE & MODAL HANDLING ───
  const openBtn = document.getElementById('openModalBtn');
  const closeBtn = document.getElementById('closeModalBtn');
  const modal = document.getElementById('leadModal');
  const leadForm = document.getElementById('leadCaptureForm');
  
  const stateSelector = document.getElementById('stateSelector');
  const serviceSelector = document.getElementById('serviceSelector');
  
  const hiddenStateInput = document.getElementById('hiddenStateInput');
  const hiddenServiceInput = document.getElementById('hiddenServiceInput');

  openBtn?.addEventListener('click', () => {
    if (!stateSelector || !serviceSelector || !hiddenStateInput || !hiddenServiceInput) return;

    const selectedState = stateSelector.value;
    const selectedService = serviceSelector.value;

    if (selectedState === "" || selectedService === "") {
      alert("Please select both a State and a Service before finding contractors.");
      return; 
    }

    const hasSubmittedBefore = localStorage.getItem('hasUnlockedContractors');

    if (hasSubmittedBefore === 'true') {
      window.location.href = `/search?state=${encodeURIComponent(selectedState)}&service=${encodeURIComponent(selectedService)}`;
    } else {
      hiddenStateInput.value = selectedState;
      hiddenServiceInput.value = selectedService;
      modal?.classList.add('is-active');
    }
  });

  leadForm?.addEventListener('submit', () => {
    localStorage.setItem('hasUnlockedContractors', 'true');
  });

  closeBtn?.addEventListener('click', () => { modal?.classList.remove('is-active'); });
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('is-active'); });


  // ─── 2. LUXURY ACCORDION FUNCTIONS ───
  function initializeLuxuryAccordions() {
    const faqItems = document.querySelectorAll(".luxury-faq-item");
    
    faqItems.forEach((item) => {
      const trigger = item.querySelector(".luxury-faq-trigger");
      const content = item.querySelector(".luxury-faq-content");
      
      if (!trigger || !content) return;

      if (item.classList.contains("active")) {
        content.style.maxHeight = content.scrollHeight + "px";
      } else {
        content.style.maxHeight = "0px";
      }

      trigger.addEventListener("click", (e) => {
        e.preventDefault();
        const isCurrentlyActive = item.classList.contains("active");

        faqItems.forEach((otherItem) => {
          if (otherItem !== item) {
            otherItem.classList.remove("active");
            const otherTrigger = otherItem.querySelector(".luxury-faq-trigger");
            const otherContent = otherItem.querySelector(".luxury-faq-content");
            if (otherTrigger) otherTrigger.setAttribute("aria-expanded", "false");
            if (otherContent) otherContent.style.maxHeight = "0px";
          }
        });

        if (isCurrentlyActive) {
          item.classList.remove("active");
          trigger.setAttribute("aria-expanded", "false");
          content.style.maxHeight = "0px";
        } else {
          item.classList.add("active");
          trigger.setAttribute("aria-expanded", "true");
          content.style.maxHeight = content.scrollHeight + "px";
        }
      });
    });
  }


  // ─── 3. INTERACTIVE MAP CONTROLLER ENGINE (ALL 30 STATES) ───
  function initializeCoverageMap() {
    const mapContainer = document.getElementById('interactive-coverage-map');
    if (!mapContainer || typeof window.L === "undefined") return;

    const L = window.L;

    if (mapContainer._leaflet_id) {
      mapContainer._leaflet_id = null;
    }

    const map = L.map('interactive-coverage-map', {
      center: [38.5, -96.0],
      zoom: 4,
      zoomControl: false,
      scrollWheelZoom: false
    });

    // FIXED: Valid CDN map tile server URL address path
