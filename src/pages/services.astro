---
import MainLayout from "../layouts/MainLayout.astro";

// This is your updated list of 13 clean services
const services = [
  "Home Builders",
  "Roofers/Siding",
  "Custom Cabinets",
  "Decks",
  "Fencing",
  "Renovations",
  "Logging",
  "Pole Barns",
  "Masonry",
  "Sheds",
  "Homegoods",
  "Home Improvement",
  "Insulation"
];
---

<MainLayout title="Our Services">
  <div class="services-container">
    <!-- Premium Brand Header Section -->
    <header class="page-header">
      <p class="subtitle">Amish Craftsmen Connection</p>
      <h1 class="title">Our Specialist Services</h1>
      <div class="accent-line"></div>
      <p class="description">
        Explore high-quality, dependable structural and finishing services provided by master traditional Amish craftsmen.
      </p>
    </header>

    <!-- Interactive Grid Layout (Replaces your plain ul list) -->
    <div class="services-grid">
      {services.map(service => {
        // Formats your URLs to match your data file structure safely
        const serviceUrl = service.toLowerCase().replaceAll(" ", "-").replaceAll("/", "-");
        
        return (
          <a href={`/services/${serviceUrl}`} class="service-card">
            <div class="card-icon">
              <!-- Universal premium layout outline icon -->
              <svg xmlns="http://w3.org" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div class="card-content">
              <h2 class="service-name">{service}</h2>
              <span class="explore-link">
                View Contractors
                <svg xmlns="http://w3.org" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</MainLayout>

<style>
   /* ─── EXACT SIZING PATCH (REDUCED PADDING TO MATCH VERTICAL HEAVY BLOCKS) ─── */
  .page-header {
    text-align: center !important;
    max-width: 1200px !important; 
    width: 100% !important;
    margin: 0 auto 40px auto !important;
    padding: 30px 40px !important; /* Fixed: Cut padding in half to instantly flatten the vertical box size */
    background-color: #2b1a11 !important; 
    border-radius: 12px !important; 
    box-sizing: border-box !important;
    box-shadow: 0 20px 50px rgba(42, 26, 18, 0.04) !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    position: relative !important;
    top: 0 !important;
    clear: both !important;
  }


  .subtitle {
    font-size: 11px !important; /* Matches contact badge layout text size */
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.25em !important;
    color: #eebb88 !important; /* Crisp premium gold variable color */
    display: block !important;
    margin-bottom: 16px !important;
  }

  .title {
    font-size: clamp(28px, 3.5vw, 42px) !important; /* Dynamic sizing matches contact header scale */
    font-weight: 400 !important;
    letter-spacing: -0.01em !important;
    color: #ffffff !important; /* Inverted clean white for rich contrast visibility */
    margin: 0 0 16px 0 !important;
    line-height: 1.3 !important;
  }

  /* Optional: Keep your custom underline or comment it out if contact has no line */
  .accent-line {
    width: 60px !important;
    height: 3px !important;
    background-color: #eebb88 !important;
    margin: 0 auto 1.5rem auto !important;
  }

  .description {
    font-size: 15px !important; /* Matches contact paragraph structural text scale */
    line-height: 1.7 !important;
    color: #c4b5a4 !important; /* Soft readable contrast cream text tint */
    max-width: 700px !important; /* Matches text alignment layout block limits */
    margin: 0 auto !important;
  }


  /* Premium Card Matrix Layout */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* Interactive Service Card Components */
  .service-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    background: #ffffff;
    border: 1px solid #eaddd3;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .service-card:hover {
    transform: translateY(-3px);
    border-color: #8b5a2b;
    box-shadow: 0 10px 15px -3px rgba(139, 90, 43, 0.1);
  }

  /* Graphic Card Accents */
  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: #f7f4f0;
    border-radius: 6px;
    color: #8b5a2b;
    flex-shrink: 0;
  }

  /* Text Elements Inside Cards */
  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .service-name {
    font-size: 1.15rem;
    color: #2c2520;
    margin: 0;
    font-weight: 600;
  }
  .explore-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    color: #8b5a2b;
    font-weight: 500;
  }
  .explore-link svg {
    transition: transform 0.15s ease;
  }
  .service-card:hover .explore-link svg {
    transform: translateX(3px);
  }
</style>
